{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditLogsResponse",
  "type": "object",
  "required": [
    "logs"
  ],
  "properties": {
    "logs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProposalLog"
      }
    }
  },
  "definitions": {
    "ProposalLog": {
      "type": "object",
      "required": [
        "description",
        "id",
        "passed",
        "title"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "id": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "passed": {
          "type": "boolean"
        },
        "title": {
          "type": "string"
        }
      }
    }
  }
}
