{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InstantiateMsg",
  "type": "object",
  "required": [
    "approval_threshold",
    "constitution_address",
    "proposers",
    "reserve_fund_address",
    "treasury_address"
  ],
  "properties": {
    "approval_threshold": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "constitution_address": {
      "type": "string"
    },
    "proposers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reserve_fund_address": {
      "type": "string"
    },
    "treasury_address": {
      "type": "string"
    }
  }
}
