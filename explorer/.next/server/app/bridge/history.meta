{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/bridge/layout,_N_T_/bridge/history/layout,_N_T_/bridge/history/page,_N_T_/bridge/history"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/bridge/history/__PAGE__",
    "/bridge/history",
    "/bridge",
    "/_index",
    "/_head"
  ]
}