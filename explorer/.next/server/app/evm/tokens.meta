{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/evm/layout,_N_T_/evm/tokens/layout,_N_T_/evm/tokens/page,_N_T_/evm/tokens"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/evm/tokens/__PAGE__",
    "/evm/tokens",
    "/evm",
    "/_index",
    "/_head"
  ]
}