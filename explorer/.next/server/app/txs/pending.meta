{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/txs/layout,_N_T_/txs/pending/layout,_N_T_/txs/pending/page,_N_T_/txs/pending"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/txs/pending/__PAGE__",
    "/txs/pending",
    "/txs",
    "/_index",
    "/_head"
  ]
}