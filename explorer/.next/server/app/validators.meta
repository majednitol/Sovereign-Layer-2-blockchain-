{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/validators/layout,_N_T_/validators/page,_N_T_/validators"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/validators/__PAGE__",
    "/validators",
    "/_index",
    "/_head"
  ]
}