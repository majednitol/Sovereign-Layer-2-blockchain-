{
  "$schema": "../chain.schema.json",
  "chain_name": "sovereign",
  "status": "live",
  "network_type": "mainnet",
  "website": "https://sovereign.l1",
  "pretty_name": "Sovereign L1",
  "chain_id": "sovereign-1",
  "bech32_prefix": "cosmos",
  "daemon_name": "chaind",
  "node_home": "$HOME/.chain",
  "key_algos": [
    "secp256k1"
  ],
  "slip44": 60,
  "fees": {
    "fee_tokens": [
      {
        "denom": "aesov",
        "fixed_min_gas_price": 0.5,
        "low_gas_price": 0.5,
        "average_gas_price": 0.75,
        "high_gas_price": 1.0
      }
    ]
  },
  "staking": {
    "staking_tokens": [
      {
        "denom": "ucsov"
      }
    ]
  },
  "codebase": {
    "git_repo": "https://github.com/majednitol/Sovereign-L1-Blockchain",
    "recommended_version": "v1.0.0",
    "compatible_versions": [
      "v1.0.0"
    ],
    "binaries": {
      "linux/amd64": "https://github.com/majednitol/Sovereign-L1-Blockchain/releases/download/v1.0.0/chaind-linux-amd64"
    }
  },
  "peers": {
    "seeds": [
      {
        "id": "abc123seednode",
        "address": "seeds.mainnet.sovereign.l1:26656",
        "provider": "Sovereign Foundation"
      }
    ],
    "persistent_peers": []
  },
  "apis": {
    "rpc": [
      {
        "address": "https://rpc.mainnet.sovereign.l1:443",
        "provider": "Sovereign Foundation"
      }
    ],
    "rest": [
      {
        "address": "https://api.mainnet.sovereign.l1:443",
        "provider": "Sovereign Foundation"
      }
    ],
    "grpc": [
      {
        "address": "grpc.mainnet.sovereign.l1:9090",
        "provider": "Sovereign Foundation"
      }
    ]
  },
  "explorers": [
    {
      "kind": "blockscout",
      "url": "https://explorer.sovereign.l1",
      "tx_page": "https://explorer.sovereign.l1/tx/${txHash}"
    }
  ]
}
